<!DOCTYPE html>
     2	<html lang="en">
     3	<head>
     4	  <meta charset="UTF-8" />
     5	  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
     6	  <title>Riyadh Urban Search Starter | Azure Maps</title>
     7	
     8	  <link href="https://atlas.microsoft.com/sdk/javascript/mapcontrol/3/atlas.min.css" rel="stylesheet" />
     9	  <script src="https://atlas.microsoft.com/sdk/javascript/mapcontrol/3/atlas.min.js"></script>
    10	  <script src="https://atlas.microsoft.com/sdk/javascript/service/2/atlas-service.min.js"></script>
    11	
    12	  <style>
    13	    html, body { height: 100%; margin: 0; font-family: "Segoe UI", Arial, sans-serif; }
    14	    #map { height: 100%; width: 100%; }
    15	
    16	    .panel {
    17	      position: absolute;
    18	      top: 12px;
    19	      left: 12px;
    20	      width: 340px;
    21	      max-height: calc(100vh - 24px);
    22	      overflow: hidden;
    23	      background: #fff;
    24	      border-radius: 10px;
    25	      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2);
    26	      z-index: 1;
    27	    }
    28	
    29	    .panel-header { padding: 12px; border-bottom: 1px solid #eee; }
    30	    .panel-title { margin: 0 0 6px; font-size: 16px; color: #153C64; }
    31	    .panel-subtitle { margin: 0; font-size: 12px; color: #666; }
    32	
    33	    #searchInput {
    34	      width: 100%;
    35	      box-sizing: border-box;
    36	      margin-top: 10px;
    37	      padding: 10px;
    38	      border: 1px solid #ccc;
    39	      border-radius: 8px;
    40	      font-size: 14px;
    41	    }
    42	
    43	    #results {
    44	      list-style: none;
    45	      margin: 0;
    46	      padding: 0;
    47	      max-height: calc(100vh - 170px);
    48	      overflow-y: auto;
    49	    }
    50	
    51	    #results li { padding: 10px 12px; border-top: 1px solid #f0f0f0; cursor: pointer; }
    52	    #results li:hover { background: #f7f9fc; }
    53	    .name { font-weight: 600; font-size: 14px; color: #222; }
    54	    .address { font-size: 12px; color: #666; margin-top: 4px; }
    55	  </style>
    56	</head>
    57	<body onload="startMap()">
    58	  <div id="map"></div>
    59	
    60	  <div class="panel">
    61	    <div class="panel-header">
    62	      <h1 class="panel-title">Riyadh Urban Places</h1>
    63	      <p class="panel-subtitle">Try: hospital, metro, park, coffee</p>
    64	      <input id="searchInput" type="text" placeholder="Search near current map center..." />
    65	    </div>
    66	    <ul id="results"></ul>
    67	  </div>
    68	
    69	  <script>
    70	    // 1) Replace this with your Azure Maps key for local demo use.
    71	    // 2) For production, never keep secrets in frontend code.
    72	    const AZURE_MAPS_KEY = 'REPLACE_WITH_YOUR_AZURE_MAPS_KEY';
    73	
    74	    // Riyadh city center
    75	    const RIYADH_CENTER = [46.6753, 24.7136];
    76	
    77	    let map;
    78	    let dataSource;
    79	    let popup;
    80	    let searchTimeout;
    81	
    82	    const searchInput = document.getElementById('searchInput');
    83	    const resultsList = document.getElementById('results');
    84	
    85	    function startMap() {
    86	      if (AZURE_MAPS_KEY === 'REPLACE_WITH_YOUR_AZURE_MAPS_KEY') {
    87	        alert('Please add your Azure Maps key in AZURE_MAPS_KEY before running this page.');
    88	      }
    89	
    90	      map = new atlas.Map('map', {
    91	        center: RIYADH_CENTER,
    92	        zoom: 11,
    93	        style: 'road',
    94	        authOptions: {
    95	          authType: 'subscriptionKey',
    96	          subscriptionKey: AZURE_MAPS_KEY
    97	        }
    98	      });
    99	
   100	      map.events.add('ready', () => {
   101	        map.controls.add(new atlas.control.ZoomControl(), { position: 'top-right' });
   102	
   103	        dataSource = new atlas.source.DataSource();
   104	        map.sources.add(dataSource);
   105	
   106	        const pins = new atlas.layer.SymbolLayer(dataSource, null, {
   107	          iconOptions: { image: 'pin-round-blue', allowOverlap: true }
   108	        });
   109	        map.layers.add(pins);
   110	
   111	        popup = new atlas.Popup();
   112	
   113	        map.events.add('click', pins, (e) => {
   114	          const shape = e.shapes && e.shapes[0];
   115	          if (!shape) return;
   116	
   117	          const p = shape.getProperties();
   118	          const name = p.poi?.name || 'Location';
   119	          const address = p.address?.freeformAddress || 'No address provided';
   120	
   121	          popup.setOptions({
   122	            position: shape.getCoordinates(),
   123	            content: `<div style="padding:10px;"><strong>${name}</strong><br>${address}</div>`
   124	          });
   125	          popup.open(map);
   126	        });
   127	      });
   128	
   129	      // Simple debounce for beginner readability.
   130	      searchInput.addEventListener('input', () => {
   131	        clearTimeout(searchTimeout);
   132	        searchTimeout = setTimeout(runSearch, 350);
   133	      });
   134	
   135	      // Enter key: focus map to all results.
   136	      searchInput.addEventListener('keydown', (e) => {
   137	        if (e.key === 'Enter') runSearch(true);
   138	      });
   139	    }
   140	
   141	    async function runSearch(zoomToResults = false) {
   142	      const query = searchInput.value.trim();
   143	      if (query.length < 2) {
   144	        dataSource?.clear();
   145	        resultsList.innerHTML = '';
   146	        return;
   147	      }
   148	
   149	      dataSource.clear();
   150	      resultsList.innerHTML = '';
   151	      popup.close();
   152	
   153	      const pipeline = atlas.service.MapsURL.newPipeline(new atlas.service.MapControlCredential(map));
   154	      const searchUrl = new atlas.service.SearchURL(pipeline);
   155	      const [lon, lat] = map.getCamera().center;
   156	
   157	      const response = await searchUrl.searchPOI(atlas.service.Aborter.timeout(10000), query, {
   158	        lon,
   159	        lat,
   160	        radius: 20000,
   161	        limit: 10,
   162	        view: 'Auto'
   163	      });
   164	
   165	      const features = response.geojson.getFeatures();
   166	      dataSource.add(features);
   167	
   168	      if (zoomToResults && features.bbox) {
   169	        map.setCamera({ bounds: features.bbox, padding: 50 });
   170	      }
   171	
   172	      features.features.forEach((feature) => {
   173	        const name = feature.properties.poi?.name || 'Location';
   174	        const address = feature.properties.address?.freeformAddress || 'No address provided';
   175	
   176	        const item = document.createElement('li');
   177	        item.innerHTML = `<div class="name">${name}</div><div class="address">${address}</div>`;
   178	
   179	        item.addEventListener('mouseenter', () => {
   180	          const shape = dataSource.getShapeById(feature.id);
   181	          if (!shape) return;
   182	
   183	          popup.setOptions({
   184	            position: shape.getCoordinates(),
   185	            content: `<div style="padding:10px;"><strong>${name}</strong><br>${address}</div>`
   186	          });
   187	          popup.open(map);
   188	        });
   189	
   190	        item.addEventListener('click', () => {
   191	          const shape = dataSource.getShapeById(feature.id);
   192	          if (!shape) return;
   193	          map.setCamera({ center: shape.getCoordinates(), zoom: 15 });
   194	        });
   195	
   196	        resultsList.appendChild(item);
   197	      });
   198	    }
   199	  </script>
   200	</body>
   201	</html>
